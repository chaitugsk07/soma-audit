# soma-audit-server environment variables.
# Copy this file to deploy/.env, fill in the values, and never commit the filled file.
#
# Required — server will refuse to start if any of these are missing.

# Postgres connection string.
DATABASE_URL=postgres://soma:soma@postgres:5432/soma_audit

# 64 lowercase hex characters (32 bytes) — HKDF master for per-tenant HMAC keys.
# Changing this invalidates all existing HMAC chain verifications (see OPERATIONS.md).
# Generate: openssl rand -hex 32
SOMA_AUDIT_MASTER_SECRET=

# 64 lowercase hex characters (32 bytes) — Ed25519 signing key for chain seals.
# Generate: openssl rand -hex 32
SOMA_AUDIT_SIGNING_KEY=

# Bearer token expected at POST /internal/v1/events (relay ingest endpoint).
# Must match the ingest_secret in RelayConfig on every client service.
# Generate: openssl rand -hex 32
SOMA_AUDIT_INGEST_SECRET=

# Bearer token for all /v1/audit/* query endpoints.
# Generate: openssl rand -hex 32
SOMA_AUDIT_ADMIN_TOKEN=

# Optional — server defaults shown below.

# Bind address (default: 0.0.0.0:8080).
# SOMA_AUDIT_BIND=0.0.0.0:8080

# Tracing filter (default: info).
# RUST_LOG=info,sqlx=warn

# Log format: set to "json" for structured output (e.g. when shipping to a log aggregator).
# LOG_FORMAT=json

# Comma-separated allowed CORS origins. Empty by default — the bundled admin
# portal is served same-origin, so no cross-origin access is granted unless you
# set this to an external dashboard origin.
# SOMA_AUDIT_CORS_ORIGINS=https://audit.example.com
